{
  "name": "player.vm.ui",
  "version": "3.0.4",
  "license": "MIT",
  "config": {
    "openapiArgs": "--additional-properties ngVersion=14.2 --additional-properties modelPropertyNaming=original --type-mappings=DateTime=string",
    "deleteGeneratedCommand": "rimraf src/app/generated/vm-api/"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest --config vitest.browser.config.ts",
    "test:browser:ui": "vitest --config vitest.browser.config.ts --ui",
    "test:browser:manual": "VITEST_BROWSER_MANUAL=1 vitest --config vitest.browser.config.ts",
    "lint": "ng lint",
    "postinstall": "node scripts/patch-akita-esm.js",
    "docker:stack": "docker stack deploy -c ./docker/api.yml vm_stack",
    "docker:stack:proxy": "docker stack deploy -c ./docker/api.yml -c ./docker/api-proxy.yml vm_stack",
    "docker:destroy": "docker stack rm vm_stack",
    "swagger:gen": "rimraf src/app/generated/vm-api/* && curl --insecure http://localhost:4302/swagger/v1/swagger.json --output swagger.json && @openapitools/openapi-generator-cli generate -i ./swagger.json -g typescript-angular -o src/app/generated/vm-api %npm_package_config_openapiArgs%",
    "swagger:gen-docker": "cross-var $npm_package_config_deleteGeneratedCommand && cross-env-shell docker run --rm -v $INIT_CWD:/local openapitools/openapi-generator-cli:v6.2.0 generate -i http://host.docker.internal:4302/swagger/v1/swagger.json?format=openapi -g typescript-angular -o /local/src/app/generated/vm-api $npm_package_config_openapiArgs",
    "swagger:gen-docker-player": "rimraf src/app/generated/player-api/ && cross-env-shell docker run --rm -v $INIT_CWD:/local openapitools/openapi-generator-cli:v6.2.0 generate -i http://host.docker.internal:4300/swagger/v1/swagger.json?format=openapi -g typescript-angular -o /local/src/app/generated/player-api --skip-validate-spec %npm_package_config_openapiArgs%"
  },
  "scriptComments": {
    "docker:stack": "// Runs the entire vm stack",
    "docker:stack:proxy": "// Runs the entire caster vm with proxy settings",
    "docker:destroy": "// Destroys the docker vm, data retained"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@cmusei/crucible-common": "0.4.3",
    "@material/material-color-utilities": "^0.4.0",
    "@datorama/akita": "^8.0.1",
    "@datorama/akita-ng-router-store": "^8.0.0",
    "@microsoft/signalr": "^10.0.0",
    "@types/uuid": "^11.0.0",
    "babel-polyfill": "^6.26.0",
    "bootstrap": "^5.3.8",
    "file-saver-es": "^2.0.5",
    "ng-table-virtual-scroll": "~1.6.1",
    "ngx-drag-to-select": "^5.0.1",
    "oidc-client-ts": "^3.4.1",
    "prettier": "^3.8.1",
    "rxjs": "^7.8.2",
    "string-natural-compare": "^3.0.1",
    "tslib": "^2.8.1",
    "tslint-config-prettier": "^1.18.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/language-service": "^21.2.1",
    "@datorama/akita-ngdevtools": "^7.0.0",
    "@openapitools/openapi-generator-cli": "2.30.2",
    "@testing-library/angular": "^19.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/browser-preview": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "cross-var": "^1.1.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "tslib": "^2.8.1"
  }
}
